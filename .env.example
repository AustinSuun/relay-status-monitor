DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
APP_ENCRYPTION_KEY="replace-with-32-byte-minimum-random-secret"
CRON_SECRET="replace-with-cron-secret"
NEXT_PUBLIC_APP_NAME="Relay Status Monitor"

# 基础初始化管理员（运行 pnpm db:seed 时使用，用户名固定为 admin）
ADMIN_PASSWORD="replace-with-a-local-admin-password"

# 演示数据（必须通过进程环境显式传入，seed 不会读取项目 .env）
DEMO_ADMIN_PASSWORD="replace-with-a-demo-admin-password"
DEMO_CRON_SECRET="replace-with-a-demo-cron-secret"
